# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
build/
dist/
.eggs/

# --- uv / virtualenv ---
.venv/
# NOTE: uv.lock and .python-version ARE committed (reproducibility) — do not ignore them.

# --- Secrets ---
.env
.env.*
!.env.example

# --- ML model cache (keep the folder, ignore downloads) ---
models/*
!models/.gitkeep

# --- Data: raw + processed are regenerated by scripts/build_all.py ---
data/raw/*
!data/raw/.gitkeep
data/processed/*
!data/processed/.gitkeep
# build artifacts, in case they ever land elsewhere
*.faiss
*.index
*.db
*.sqlite
*.sqlite3

# --- Editor / tooling / CI (kept local) ---
.vscode/
.github/copilot-instructions.md
.idea/
.ruff_cache/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
.coverage
htmlcov/

# --- OS ---
.DS_Store
Thumbs.db